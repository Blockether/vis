;; Monorepo root — and `vis-core`'s own `deps.edn`.
;;
;; vis-core IS the project: the host runtime, the SCI sandbox, the
;; iteration loop, the CLI dispatcher, the extension/channel/provider
;; registries, and the persistence facade. Its source lives at the
;; repo root (`src/`, `test/`, `resources/`) — every classpath plug-in
;; under `extensions/<category>/<pkg>/` declares `:local/root "../../.."`
;; against this file.
;;
;; `extensions/` is grouped by surface category:
;;   `extensions/channels/`     — vis-tui, vis-telegram
;;   `extensions/providers/`    — vis-provider-github-copilot
;;   `extensions/persistance/`  — vis-persistance-sqlite
;;   `extensions/common/`       — vis-meta, vis-editing
;;
;; Top-level `:deps` is vis-core's library dependency map and is what
;; build.clj copies into the published `com.blockether/vis-core` POM.
;; Aliases pull in optional plug-ins for development, the binary,
;; tests, and benchmarks. The aliases never reach the published POM.
;;
;; The repo-root `bin/vis` wrapper just `exec`s `clojure -M:vis "$@"`,
;; so daily use is `vis <subcommand>` once `bin/` is on PATH.
{:paths ["src" "resources"]

 :deps
 {org.clojure/clojure                       {:mvn/version "1.12.4"}
  ;; dynaload — used for optional/lazy runtime integrations.
  borkdude/dynaload                         {:mvn/version "0.3.5"}
  ;; Flyway core — migration runner used by the persistence facade.
  ;; Dialect-specific drivers live in backend extension packages.
  org.flywaydb/flyway-core                  {:mvn/version "12.4.0"}

  hiccup/hiccup                             {:mvn/version "2.0.0"}
  ;; LLM structured output
  com.blockether/svar                       {:mvn/version "0.3.11"}
  ;; Anomaly — standardized error categories (used by RLM)
  com.blockether/anomaly                    {:mvn/version "1.0.1"}
  ;; Browser automation (Playwright)
  com.blockether/spel                       {:mvn/version "0.9.7"}
  ;; Ring — Jetty adapter
  ring/ring-jetty-adapter                   {:mvn/version "1.15.4"}
  ;; Reitit — data-driven router
  metosin/reitit-ring                       {:mvn/version "0.10.1"}
  ;; nREPL — embedded in dev + prod
  nrepl/nrepl                               {:mvn/version "1.7.0"}
  ;; Structured telemetry
  com.taoensso/telemere                     {:mvn/version "1.2.1"}
  com.taoensso/telemere-slf4j               {:mvn/version "1.2.1"}

  ;; Fast EDN parsing
  io.github.tonsky/fast-edn                 {:mvn/version "1.1.3"}
  ;; JSON serialization (CLI output, agent results)
  com.cnuernber/charred                     {:mvn/version "1.038"}

  ;; ---- RLM stack (moved from svar) ----
  ;; Filesystem utilities
  babashka/fs                               {:mvn/version "0.5.33"}
  ;; SCI — Small Clojure Interpreter (RLM sandbox)
  org.babashka/sci                          {:mvn/version "0.12.51"}
  ;; HTTP client (pageindex vision calls etc.)
  org.babashka/http-client                  {:mvn/version "0.4.23"}
  ;; zprint — pretty printer (RLM sandbox)
  zprint/zprint                             {:mvn/version "1.3.0"}
  ;; Edamame — edn/clj reader (richer than clojure.edn)
  borkdude/edamame                          {:mvn/version "1.5.39"}
  ;; core.async — parallel processing (pageindex)
  org.clojure/core.async                    {:mvn/version "1.9.865"}
  ;; lazytest — exposed in RLM SCI sandbox
  io.github.noahtheduke/lazytest            {:mvn/version "2.0.0"}
  ;; clojure+ — cond+/if+/when+ macros + enhanced walk (SCI sandbox)
  io.github.tonsky/clojure-plus             {:mvn/version "1.7.2"}
  ;; jmustache — Mustache templating (RLM answer interpolation)
  com.samskivert/jmustache                  {:mvn/version "1.16"}}

 :aliases
 {;; Dev REPL helpers + every classpath plug-in available for nREPL,
  ;; so `cider-jack-in` from the repo root can touch the whole product.
  :dev   {:extra-paths []
          :extra-deps  {cider/cider-nrepl                          {:mvn/version "0.59.0"}
                        io.github.tonsky/clj-reload                {:mvn/version "1.0.0"}
                        com.blockether/vis-editing                 {:local/root "extensions/common/vis-editing"}}}

  ;; Primary alias — the `vis` CLI dispatcher. The repo-root `bin/vis`
  ;; wrapper just `exec`s `clojure -M:vis "$@"`, so day-to-day use is
  ;; `vis <subcommand>` with no Clojure visible. Every classpath
  ;; plug-in is pulled in as `:extra-deps` so the unified extension
  ;; loader (`META-INF/vis-extension/vis.edn`) discovers them at boot.
  :vis   {;; JVM flags here exist purely to keep stderr quiet so the TUI
          ;; (Lanterna) is not corrupted by JVM-emitted warnings:
          ;;   --enable-native-access=ALL-UNNAMED
          ;;       Silences JEP 472 "restricted method" warnings from
          ;;       JNI/native libs (e.g. SQLite native, jline).
          ;;   --sun-misc-unsafe-memory-access=allow
          ;;       Silences JEP 498 "terminally deprecated method in
          ;;       sun.misc.Unsafe has been called" warnings emitted
          ;;       by io.airlift.aircompressor (LZ4, pulled in via
          ;;       com.taoensso/nippy → vis-persistance-sqlite). The
          ;;       warning fires on first compress, which can happen
          ;;       AFTER Lanterna has taken the screen — even with
          ;;       System.err redirected to ~/.vis/vis.log it still
          ;;       garbles the TUI on some code paths. Killing it at
          ;;       the JVM level is the only reliable fix.
          ;;   -XX:+IgnoreUnrecognizedVMOptions
          ;;       Lets older JDKs that don't know the two flags above
          ;;       boot anyway instead of refusing to start.
          :jvm-opts   ["-XX:+IgnoreUnrecognizedVMOptions"
                       "--enable-native-access=ALL-UNNAMED"
                       "--sun-misc-unsafe-memory-access=allow"]
          :extra-deps {com.blockether/vis-persistance-sqlite       {:local/root "extensions/persistance/vis-persistance-sqlite"}
                       com.blockether/vis-provider-github-copilot  {:local/root "extensions/providers/vis-provider-github-copilot"}
                       com.blockether/vis-telegram                 {:local/root "extensions/channels/vis-telegram"}
                       com.blockether/vis-tui                      {:local/root "extensions/channels/vis-tui"}
                       com.blockether/vis-editing                  {:local/root "extensions/common/vis-editing"}
                       com.blockether/vis-meta                     {:local/root "extensions/common/vis-meta"}}
          :main-opts  ["-m" "com.blockether.vis.commandline.main"]}

  ;; Aggregate test runner. The root `test/` tree carries vis-core's
  ;; own tests; every extension that ships tests is listed below so a
  ;; single `clojure -M:test` exercises the whole product on one
  ;; classpath. Add a new `--dir` entry only when an extension grows
  ;; its first test — lazytest errors on "no namespaces to run" if a
  ;; listed dir is empty.
  :test  {:extra-paths ["test"
                        "extensions/persistance/vis-persistance-sqlite/test"
                        "extensions/channels/vis-tui/test"
                        "extensions/common/vis-editing/test"
                        "extensions/common/vis-meta/test"]
          :extra-deps  {io.github.noahtheduke/lazytest             {:mvn/version "2.0.0"}
                        com.blockether/vis-persistance-sqlite      {:local/root "extensions/persistance/vis-persistance-sqlite"}
                        com.blockether/vis-tui                     {:local/root "extensions/channels/vis-tui"}
                        com.blockether/vis-editing                 {:local/root "extensions/common/vis-editing"}
                        com.blockether/vis-meta                    {:local/root "extensions/common/vis-meta"}}
          :main-opts   ["-m" "lazytest.main"
                        "--dir" "test"
                        "--dir" "extensions/persistance/vis-persistance-sqlite/test"
                        "--dir" "extensions/channels/vis-tui/test"
                        "--dir" "extensions/common/vis-editing/test"
                        "--dir" "extensions/common/vis-meta/test"]}

  :bench {:extra-deps {com.blockether/vis-benchmark {:local/root "benchmarks"}}
          :jvm-opts    ["-Xmx8g"]
          :main-opts   ["-m" "com.blockether.vis.bench.runner"]}

  :build {:deps  {io.github.clojure/tools.build {:mvn/version "0.10.13"}
                  slipset/deps-deploy           {:mvn/version "0.2.3"}}
          :ns-default build}

  :antq  {:deps  {com.github.liquidz/antq {:mvn/version "RELEASE"}}
          :main-opts ["-m" "antq.core"]}}}
