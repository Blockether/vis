;; Project-level clj-kondo config.
{:lint-as
 {lazytest.core/defdescribe clojure.test/deftest
  lazytest.core/around-each clojure.core/fn
  ;; `vis/validator-fn` is an authoring sugar over `(fn arglist body)`.
  ;; Same arglist semantics; tell kondo to lint it as a plain fn so
  ;; destructured bindings in the body resolve.
  com.blockether.vis.core/validator-fn clojure.core/fn}

 ;; `with-python-context` (sandbox-shim tests) is an anaphoric macro that binds
 ;; `python-context`; tell kondo the symbol is intentional, not a typo.
 :linters
 {:unresolved-symbol {:exclude [python-context]}
  ;; Telemere generates these vars through macros, so dependency analysis cannot
  ;; discover them even though they resolve at compile time.
  :unresolved-var
  {:exclude [taoensso.telemere/handler:file
             taoensso.telemere/handler:console
             taoensso.telemere/call-on-shutdown!]}}

 :hooks
 {:analyze-call
  {;; Macro that wraps a runtime backend lookup behind a defn.
   ;; Without this hook every `defdelegate` call shows up as an
   ;; unresolved-symbol error because clj-kondo can't expand the
   ;; runtime resolution. See the hook for details.
   com.blockether.vis.internal.persistance/defdelegate
   hooks.com.blockether.vis.defdelegate/defdelegate

   ;; In-house `import-vars`/`import-var` re-export the public facade
   ;; (com.blockether.vis.core). Expand each re-export into a synthetic
   ;; `def` so `vis/<alias>` resolves at every call site across the repo.
   com.blockether.vis.internal.import/import-vars
   hooks.com.blockether.vis.import-vars/import-vars
   com.blockether.vis.internal.import/import-var
   hooks.com.blockether.vis.import-vars/import-var
   ;; Per-file `with-tmp` fixtures used by vis-foundation tests:
   ;; bind a fresh tmp-dir path to the symbol passed in. Without
   ;; the hook every `(with-tmp root ...)` call lights every `root`
   ;; reference in the body up as `unresolved-symbol`.
   com.blockether.vis.internal.foundation.environment.agents-test/with-tmp
   hooks.com.blockether.vis.with-tmp/with-tmp
   com.blockether.vis.internal.foundation.environment.skills-test/with-tmp
   hooks.com.blockether.vis.with-tmp/with-tmp}}}
