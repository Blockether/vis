#!/usr/bin/env bash
# install — single entry point that dispatches to the right Vis installer.
#
# One command for every platform; it figures out the OS and runs the matching
# installer. Mirrors rustup / deno / homebrew.
#
#   macOS / Linux:   curl -fsSL https://raw.githubusercontent.com/Blockether/vis/main/install | bash
#   Windows:         run install-source.ps1 in PowerShell (see message below if run from Git Bash)
#
# This dispatcher is bash because bash is the universal denominator — present
# on macOS/Linux natively and on Windows via Git Bash / WSL / MSYS2. It never
# installs anything itself; it only routes to bin/install-source (unix) or
# points Windows users at bin/install-source.ps1.

set -euo pipefail

repo_raw="${VIS_INSTALL_RAW:-https://raw.githubusercontent.com/Blockether/vis/main}"
unix_installer="bin/install-source"
win_installer="bin/install-source.ps1"

# Locate a local checkout of the installer relative to THIS script's dir, so a
# run from a clone is instant and offline. When piped via `curl | bash` there's
# no local copy, so we re-fetch from raw GitHub instead.
local_installer=""
src="${BASH_SOURCE[0]:-$0}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
script_dir="$(cd -P "$(dirname "$src")" && pwd)"
if [ -f "$script_dir/$unix_installer" ]; then
  local_installer="$script_dir/$unix_installer"
fi

err() { echo "vis install: $*" >&2; }

# Hand off to the unix installer, preferring a local copy over a network fetch.
run_unix() {
  if [ -n "$local_installer" ]; then
    exec bash "$local_installer" "$@"
  fi
  if ! command -v curl >/dev/null 2>&1; then
    err "need 'curl' to fetch the installer (or run from a Vis checkout)."
    exit 1
  fi
  # Fetch the installer and pipe it to bash, forwarding our args as the
  # installer's "$@". `bash -s --` is required: `-s` reads the script from
  # stdin, and `--` stops bash from eating flags like --help/--branch as its
  # own. The URL is $0 (cosmetic only).
  exec bash -c 'curl -fsSL "$0" | bash -s -- "$@"' "$repo_raw/$unix_installer" "$@"
}

# Windows via Git Bash / MSYS / Cygwin: the bash installer uses ln -sfn, which
# can't build a working Windows shim. Point the user at the native PowerShell
# installer instead of half-working.
run_windows() {
  cat >&2 <<EOF
vis install: you're on Windows (running under Git Bash / MSYS).

The bash installer creates unix symlinks and won't produce a working Windows
launcher. Run the PowerShell installer instead — open PowerShell and paste:

  iwr $repo_raw/$win_installer -OutFile install-vis.ps1
  powershell -ExecutionPolicy Bypass -File .\\install-vis.ps1

(WSL users: run this same command from inside WSL, where it's Linux.)
EOF
  exit 0
}

case "${OSTYPE:-}" in
  darwin*|linux*|freebsd*|openbsd*|netbsd*) run_unix "$@" ;;
  msys|mingw*|cygwin)                        run_windows ;;
  "")
    # OSTYPE is sometimes unset under non-interactive `curl | bash` pipes.
    # Fall back to uname; treat anything but MINGW/MSYS/Cygwin as unix.
    os="$(uname -s 2>/dev/null || echo unknown)"
    case "$os" in
      MINGW*|MSYS*|Cygwin*) run_windows ;;
      *)                    run_unix "$@" ;;
    esac
    ;;
  *) err "unrecognized OSTYPE='${OSTYPE:-}'. File a bug? Falling back to the unix installer." ; run_unix "$@" ;;
esac
