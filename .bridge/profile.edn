{:subsystems
 [{:name "bridge-extension",
   :code-globs ["extensions/common/vis-foundation-bridge/src/**/*"],
   :docs-globs ["extensions/common/vis-foundation-bridge/docs/**/*"],
   :test-globs ["extensions/common/vis-foundation-bridge/test/**/*"],
   :expected-artifacts
   ["change-intent-card" "verification-brief" "completeness-ledger"],
   :expected-evidence ["unit"],
   :system-category "api",
   :risk-class "medium"}],
 :project-name "vis",
 :artifact-paths
 {:root ".bridge/ephemeral",
  :phases ".bridge/ephemeral/phases",
  :evidence ".bridge/ephemeral/evidence",
  :evaluations ".bridge/ephemeral/evaluations"},
 :test-paths ["test"],
 :docs-paths ["docs"],
 :phases [],
 :kind "project-profile",
 :verification-policy-path ".bridge/verification-policy.yaml",
 :code-paths ["src"],
 :root-path "..",
 :canonical-commands
 [{:id "unit",
   :kind "unit",
   :role "regression",
   :command "cd extensions/common/vis-foundation-bridge && clojure -M:test",
   :description "Run unit tests",
   :result-parser {:type "regex-status",
                   :rules
                   [{:stream :stdout, :regex "0 failures", :status "passed"},
                    {:stream :stdout, :regex "[^0] failures", :status "failed"}]}}]}
