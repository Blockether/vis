{:paths ["src" "resources"]
 ;; Editing extension only depends on the slim extension contract,
 ;; NOT the full vis runtime. Same module that vis-core itself uses,
 ;; just pulled directly so this jar stays small and decoupled.
 :deps {com.blockether/vis-extension {:local/root "../../packages/vis-extension"}
        ;; RE2/J — linear-time regex (ReDoS-safe). Used by the grep tool so
        ;; agent-supplied patterns can never burn the box with catastrophic
        ;; backtracking. No native deps, pure Java, license Go-BSD.
        com.google.re2j/re2j         {:mvn/version "1.8"}
        ;; .gitignore parsing for `(fs/list-files)` and `(fs/grep-files)`.
        org.eclipse.jgit/org.eclipse.jgit {:mvn/version "6.10.0.202406032230-r"}}}
