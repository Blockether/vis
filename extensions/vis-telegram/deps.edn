{:paths ["src" "resources"]
 ;; Telegram channel — Bot API long-poll loop wired into the
 ;; conversation runtime. Optional channel package.
 ;;
 ;; Depends on vis-core for `conversations/for-telegram-chat!` and
 ;; `conversations/send!`. The CLI dispatcher resolves
 ;; `com.blockether.vis.channels.telegram.bot/-main` lazily via
 ;; `requiring-resolve`, so omitting this jar still leaves the rest
 ;; of vis usable.
 :deps
 {org.clojure/clojure      {:mvn/version "1.12.4"}
  com.blockether/vis-core  {:local/root "../../packages/vis-core"}
  org.babashka/http-client {:mvn/version "0.4.23"}
  com.cnuernber/charred    {:mvn/version "1.038"}
  com.taoensso/telemere    {:mvn/version "1.2.1"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.noahtheduke/lazytest {:mvn/version "2.0.0"}}
   :main-opts  ["-m" "lazytest.main"]}}}
