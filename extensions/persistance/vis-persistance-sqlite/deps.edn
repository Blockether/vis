{:paths ["src" "resources"]
 ;; SQLite backend for the vis persistence facade.
 ;;
 ;; Owns:
 ;;   - sqlite-jdbc, next.jdbc, honeysql, nippy (the JDBC plumbing)
 ;;   - flyway-core + flyway-database-nc-sqlite (the migration runner
 ;;     and the dialect-specific Flyway driver). Both used to ride
 ;;     along the root vis package; they moved here because this is
 ;;     the only consumer of either, and `migrate!` itself is a
 ;;     dialect concern, not core runtime.
 ;;   - the SQLite SQL migration resources (resources/db/sqlite/migration/)
 ;;
 ;; Loading `com.blockether.vis.ext.persistance-sqlite.core` auto-registers
 ;; the `:sqlite` backend with the facade. `db-open!` invokes
 ;; `vis-runtime`'s `persistance.migration/migrate!` against
 ;; `classpath:db/sqlite/migration` (SQL ships in this package) so
 ;; every store starts with the canonical schema applied.
 :deps
 {org.clojure/clojure                       {:mvn/version "1.12.5"}
  ;; vis-sdk owns the extension-registration contract;
  ;; vis-sdk owns the storage facade. vis-sdk transitively
  ;; pulls both via the dep below.
  com.blockether/vis                   {:local/root "../../.."}
  ;; Binary serialization for definition_state.value blobs
  com.taoensso/nippy                        {:mvn/version "3.7.0-RC2"}
  ;; JSON (used inside the SQLite query layer for blob round-trips)
  com.cnuernber/charred                     {:mvn/version "1.039"}
  ;; SQLite + JDBC
  org.xerial/sqlite-jdbc                    {:mvn/version "3.53.2.0"}
  com.github.seancorfield/next.jdbc         {:mvn/version "1.3.1118"}
  com.github.seancorfield/honeysql          {:mvn/version "2.7.1399"}
  ;; Real connection pool. xerial's `SQLiteConnectionPoolDataSource`
  ;; is a JNDI-shaped façade that opens a NEW physical SQLite
  ;; connection on every `getConnection()` - it does NOT pool. Under
  ;; bursty workloads (5-10 db-store-iteration! writes per agent turn)
  ;; this churns WAL/-shm files, can race with directory-level
  ;; events on macOS APFS, and surfaces sporadic SQLITE_CANTOPEN.
  ;; HikariCP wraps the underlying `SQLiteDataSource` with a real
  ;; pool of long-lived connections, eliminating the open/close
  ;; thrash and giving us a single dispose hook that actually
  ;; releases handles.
  com.zaxxer/HikariCP                       {:mvn/version "7.1.0"}
  ;; Flyway core - owns schema migration for this backend.
  org.flywaydb/flyway-core                  {:mvn/version "12.10.0"}
  ;; SQLite-specific Flyway driver. Split out of flyway-core in 10.x+
  ;; - without this jar Flyway can't recognize a `jdbc:sqlite:` URL.
  org.flywaydb/flyway-database-nc-sqlite    {:mvn/version "12.10.0"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.noahtheduke/lazytest {:mvn/version "2.0.0"}}
   :main-opts  ["-m" "lazytest.main"]}}}
