{:paths ["src" "resources"]
 ;; TUI channel - Lanterna-based chat UI. Optional channel package.
 ;;
 ;; Depends on vis-sdk for the runtime (sessions, env, turns, db).
 ;; vis-runtime never requires this namespace directly - the CLI dispatcher
 ;; resolves `com.blockether.vis.ext.channel-tui.screen/run-chat!` lazily
 ;; via `requiring-resolve`, so omitting this jar still leaves the rest
 ;; of vis usable.
 :deps
 {org.clojure/clojure              {:mvn/version "1.12.4"}
  com.blockether/vis          {:local/root "../../.."}
  ;; Blockether fork of mabe02/lanterna 3.1.5 — STANDARD Unicode widths, so
  ;; lanterna's column model matches what the terminal paints (mismatch shoves
  ;; following cells / borders out of alignment). Patches on top of 3.1.5:
  ;;   1. PR #625 cherry-pick — grapheme-aware emoji rendering in
  ;;      StreamBasedTerminal/AbstractTextGraphics putString.
  ;;   2. BMP `Emoji_Presentation=Yes` glyphs (✅ ⭐ ⚡ ❌ ✨ ☔ ☕ ⏰ …) and
  ;;      genuine astral/surrogate emoji (🏷️ 😊 👀) → 2 columns.
  ;;   3. VS-16 width is BASE-dependent: a text-default BMP symbol + VS-16
  ;;      (⚠️ ❤️ ☑️ — base U+26A0/U+2764/U+2611) stays NARROW (1 col); only a
  ;;      genuine emoji base (astral, or Emoji_Presentation=Yes) widens. Forcing
  ;;      the text-symbol forms wide over-counted the row and shoved borders left.
  ;;   4. VS-15 text-presentation graphemes (☑︎) stay single-width.
  ;;   5. Geometric / symbol glyphs ● ○ ◯ ◎ ◐ ◑ (status dots), ▶ ◀ (media
  ;;      triangles), ⚠ (warning sign) are ONE column (standard width). They were
  ;;      briefly force-widened; that mis-aligned e.g. a focused tab's `● ` prefix
  ;;      (its trailing │ slid one column left). Disclosure chevrons ▸ ▾ already
  ;;      narrow (EAW=N).
  ;;   6. East-Asian-Ambiguous (EAW=A) punctuation/letters (· — … λ “” • ™, Greek,
  ;;      Cyrillic) are NARROW by default (modern terminals); opt into wide with
  ;;      the JVM flag `-Dlanterna.eastAsianAmbiguousWide=true`.
  ;;   7. East-Asian Wide/Fullwidth (EAW=W/F) table from Unicode 15.1 for W/F
  ;;      symbols OUTSIDE the CJK blocks (〈〉, Yi, Bopomofo, CJK compat/vertical)
  ;;      that isCharCJK missed → 2 columns. One shared source for display-width
  ;;      and the paint. Chrome (box/block/geometric/arrows) stays single-width.
  ;;   8. Control chars degrade to a space instead of throwing on the render thread.
  ;; Drop-in replacement — same com.googlecode.lanterna.* package namespace.
  ;; Retire when upstream ships equivalent fixes.
  com.blockether/lanterna          {:mvn/version "3.1.5-vis.12"}
  com.blockether/vis-provider-anthropic {:local/root "../../providers/vis-provider-anthropic"}
  com.blockether/vis-provider-github-copilot {:local/root "../../providers/vis-provider-github-copilot"}
  com.blockether/vis-provider-openai-codex {:local/root "../../providers/vis-provider-openai-codex"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.noahtheduke/lazytest {:mvn/version "2.0.0"}
                ;; Used by `render_bench_test.clj` for the inline
                ;; Markdown hot-path microbenchmarks. Test-only;
                ;; never reaches the runtime jar.
                criterium/criterium {:mvn/version "0.4.6"}}
   :main-opts  ["-m" "lazytest.main"]}}}
