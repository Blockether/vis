{:paths ["src" "resources"]
 ;; TUI channel - Lanterna-based chat UI. Optional channel package.
 ;;
 ;; Depends on vis-sdk for the runtime (sessions, env, turns, db).
 ;; vis-runtime never requires this namespace directly - the CLI dispatcher
 ;; resolves `com.blockether.vis.ext.channel-tui.screen/run-chat!` lazily
 ;; via `requiring-resolve`, so omitting this jar still leaves the rest
 ;; of vis usable.
 :deps
 {org.clojure/clojure              {:mvn/version "1.12.4"}
  com.blockether/vis          {:local/root "../../.."}
  ;; Blockether fork of mabe02/lanterna 3.1.5 with eight patches on top:
  ;;   1. PR #625 cherry-pick - emoji rendering in
  ;;      StreamBasedTerminal/AbstractTextGraphics putString.
  ;;   2. BMP `Emoji_Presentation=Yes` width detection - ✅, ⭐, ⚡,
  ;;      ❌, ✨, ☔, ☕, ⏰, etc. (≈30 ranges, ≈100 code points)
  ;;      now correctly counted as 2 terminal columns.
  ;;   3. VS-16 (emoji-presentation) graphemes are WIDE — ⚠️ ❤️ ☑️ 🏷️
  ;;      count as 2 columns, matching emoji-wide target terminals so the
  ;;      following text/border/scrollbar stays aligned. (VS-15 text
  ;;      presentation stays narrow — patch #4.)
  ;;   4. VS-15 text-presentation graphemes (☑︎) stay single-width.
  ;;   5. East-Asian-Ambiguous (EAW=A) width - curated text punctuation
  ;;      and letters (· — … λ “” • ™, Greek, Cyrillic) are NARROW by
  ;;      default (single column), matching modern terminals. Forcing
  ;;      them wide over-advanced the cursor on ordinary prose and
  ;;      produced scroll-redraw artifacts / misaligned borders. Opt
  ;;      into wide for genuine ambiguous-wide terminals with the JVM
  ;;      flag `-Dlanterna.eastAsianAmbiguousWide=true`.
  ;;   6. East-Asian Wide/Fullwidth (EAW=W / EAW=F) width table generated
  ;;      from Unicode 15.1 EastAsianWidth.txt. W/F symbols OUTSIDE the CJK
  ;;      Unicode blocks (angle brackets 〈〉, Yi, Bopomofo, CJK compat /
  ;;      vertical forms) used to slip through isCharCJK and undercount by a
  ;;      column, drifting the scrollbar / following cells. Now one shared
  ;;      double-width source for both display-width and the paint. Ambiguous
  ;;      (EAW=A) is untouched (still narrow by default); chrome (box/block/
  ;;      geometric/arrows) stays single-width.
  ;;   7. Emoji=Yes media triangles ▶ U+25B6 / ◀ U+25C0 (Emoji_Presentation=No,
  ;;      so missed by #2) → 2 columns; the target terminal paints them
  ;;      emoji-wide. The SMALL triangles ▸ ▾ used for disclosure chevrons
  ;;      stay single-width (EAW=N, non-emoji).
  ;;   8. ⚠ U+26A0 WARNING SIGN (Emoji=Yes, Emoji_Presentation=No, also missed
  ;;      by #2/#3 in its BARE form) → 2 columns; the bare glyph paints emoji-
  ;;      wide so "⚠ …" status lines no longer jam a tooth into the right
  ;;      border. The VS-16 form ⚠️ was already wide via #3.
  ;; Drop-in replacement - same com.googlecode.lanterna.* package namespace.
  ;; Retire when upstream ships equivalent fixes.
  com.blockether/lanterna          {:mvn/version "3.1.5-vis.11"}
  com.blockether/vis-provider-anthropic {:local/root "../../providers/vis-provider-anthropic"}
  com.blockether/vis-provider-github-copilot {:local/root "../../providers/vis-provider-github-copilot"}
  com.blockether/vis-provider-openai-codex {:local/root "../../providers/vis-provider-openai-codex"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.noahtheduke/lazytest {:mvn/version "2.0.0"}
                ;; Used by `render_bench_test.clj` for the inline
                ;; Markdown hot-path microbenchmarks. Test-only;
                ;; never reaches the runtime jar.
                criterium/criterium {:mvn/version "0.4.6"}}
   :main-opts  ["-m" "lazytest.main"]}}}
