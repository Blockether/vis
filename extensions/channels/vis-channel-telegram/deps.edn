{:paths ["src" "resources"]
 ;; Telegram channel - Bot API long-poll loop wired into the
 ;; session runtime. Optional channel package.
 ;;
 ;; Depends on vis-sdk for `sessions/for-telegram-chat!` and
 ;; `sessions/send!`. The CLI dispatcher resolves
 ;; `com.blockether.vis.ext.channel-telegram.bot/-main` lazily via
 ;; `requiring-resolve`, so omitting this jar still leaves the rest
 ;; of vis usable.
 :deps
 {org.clojure/clojure      {:mvn/version "1.12.5"}
  com.blockether/vis  {:local/root "../../.."}
  org.babashka/http-client {:mvn/version "0.4.23"}
  babashka/process         {:mvn/version "0.6.25"}
  com.cnuernber/charred    {:mvn/version "1.039"}
  com.taoensso/telemere    {:mvn/version "1.2.1"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.noahtheduke/lazytest {:mvn/version "2.0.0"}}
   :main-opts  ["-m" "lazytest.main"]}}}
