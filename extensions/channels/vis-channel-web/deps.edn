{:paths ["src" "resources"]
 ;; Web companion channel - the `/ui` two-pane instrument served by the
 ;; HTTP gateway. Optional channel package: drop
 ;; the jar, drop /ui; the gateway keeps serving the pure JSON API.
 ;;
 ;; Auto-mount: loading this extension's ns (via the META-INF
 ;; vis-extension manifest classpath scan) registers a route
 ;; contribution with `vis.core/gateway-register-routes!` - no wiring in
 ;; the gateway, no channel-specific code in core. Pure Clojure SSR:
 ;; hiccup renders, HTMX (CDN) swaps, SSE streams HTML fragments.
 :deps
 {org.clojure/clojure   {:mvn/version "1.12.5"}
  com.blockether/vis    {:local/root "../../.."}
  hiccup/hiccup         {:mvn/version "2.0.0"}
  com.taoensso/telemere {:mvn/version "1.2.1"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.noahtheduke/lazytest {:mvn/version "2.0.0"}}
   :main-opts  ["-m" "lazytest.main"]}}}
