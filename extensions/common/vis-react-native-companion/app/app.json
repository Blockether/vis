{
  "expo": {
    "name": "vis",
    "slug": "vis-react-native-companion",
    "scheme": "visrn",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      [
        "expo-audio",
        { "microphonePermission": "vis records short voice prompts and transcribes them locally on your gateway." }
      ]
    ]
  }
}
