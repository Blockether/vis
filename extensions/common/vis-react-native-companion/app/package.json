{
  "name": "vis-react-native-companion",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "EXPO_NO_TYPESCRIPT_SETUP=1 expo start --host localhost",
    "android": "EXPO_NO_TYPESCRIPT_SETUP=1 expo start --android --host localhost",
    "ios": "EXPO_NO_TYPESCRIPT_SETUP=1 expo start --ios --host localhost",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "prebuild:ios": "expo prebuild --platform ios",
    "pods": "cd ios && pod install",
    "xcode": "xed ios/vis.xcworkspace",
    "deploy:ios": "bash scripts/deploy-ios.sh",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "expo": "~54.0.0",
    "expo-audio": "~1.1.1",
    "expo-document-picker": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.7",
    "expo-splash-screen": "~31.0.13",
    "react": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-sse": "^1.2.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "expo-asset": "~12.0.13",
    "expo-font": "~14.0.12"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"],
    "testMatch": ["<rootDir>/src/**/*.test.ts", "<rootDir>/src/**/*.test.tsx"],
    "transformIgnorePatterns": ["node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-sse))"]
  }
}
