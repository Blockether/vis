{:paths ["src" "resources"]
 :deps  {com.blockether/vis {:local/root "../../.."}
         ;; Apache MINA SSHD-backed SshSessionFactory for JGit. Without
         ;; this, the default factory cannot read ~/.ssh/config /
         ;; IdentityFile the way OpenSSH does, and pushes to GitHub fail
         ;; mid-handshake with "remote hung up unexpectedly"
         ;; (TransportException). The Apache sshd factory understands
         ;; ssh-config, ed25519 keys, ssh-agent, and rsa-sha2-512 — i.e.
         ;; everything GitHub currently insists on. Only the git/push! /
         ;; git/fetch! write-ops install it, so the dep belongs here
         ;; (extension-local) instead of the root deps.edn.
         org.eclipse.jgit/org.eclipse.jgit.ssh.apache
         {:mvn/version "7.7.0.202606012155-r"}
         ;; OSGi fragment for org.eclipse.jgit.ssh.apache. Registers a
         ;; `ConnectorFactory` via `ServiceLoader` so JGit's
         ;; `SshdSessionFactory` actually talks to `$SSH_AUTH_SOCK` over
         ;; a Unix domain socket (JNA + jna-platform) — i.e. uses the
         ;; running ssh-agent instead of reading identity files off
         ;; disk. Without this fragment, MINA SSHD walks `~/.ssh/`
         ;; directly and presents `id_ed25519` *plus* its
         ;; `id_ed25519-cert.pub` sibling. GitHub rejects the cert
         ;; (CA not trusted) and the channel closes — surfaced as
         ;; `remote hung up unexpectedly`. With the agent fragment on
         ;; the classpath, MINA SSHD never offers the cert; the agent
         ;; hands over only the bare ed25519 pubkey and the handshake
         ;; succeeds (Vis t6/i5: confirmed `ConnectorFactory` missing
         ;; in the running JVM even after foundation-git is required).
         org.eclipse.jgit/org.eclipse.jgit.ssh.apache.agent
         {:mvn/version "7.7.0.202606012155-r"}}}
