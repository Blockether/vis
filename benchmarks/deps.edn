{:paths ["src" "data"]
 ;; Benchmark harness — 4clojure, HumanEval, SWE-bench Verified.
 ;;
 ;; Optional package: NOT loaded by the default product distribution.
 ;; Pulled in via the repo-root `:bench` alias (or by anyone who adds
 ;; `com.blockether/vis-benchmark` as an explicit dep).
 ;;
 ;; Working directories (`results/`, `trajectories/`, `swebench-harness/`)
 ;; are created on demand at runtime under this package's root.
 :deps
 {org.clojure/clojure        {:mvn/version "1.12.4"}
  ;; Runtime — RLM env, query engine, persistence, providers
  com.blockether/vis-loop    {:local/root "../packages/vis-loop"}
  ;; Structured LLM I/O (also a transitive dep of vis-loop, but listed
  ;; explicitly because the bench harness uses svar/router directly)
  com.blockether/svar        {:mvn/version "0.3.11"}
  ;; JSON dataset parsing
  com.cnuernber/charred      {:mvn/version "1.038"}
  ;; Filesystem helpers
  babashka/fs                {:mvn/version "0.5.33"}
  ;; Telemetry
  com.taoensso/telemere      {:mvn/version "1.2.1"}
  com.taoensso/trove         {:mvn/version "1.1.0"}}

 :aliases
 {:run  {:main-opts ["-m" "com.blockether.vis.bench.runner"]
         :jvm-opts  ["-Xmx8g"]}}}
