#!/usr/bin/env bash
# Clone or update the Vis source checkout under ~/.vis/sourcecode.
# Checks the runtime tools needed to run Vis from source before touching disk.

set -euo pipefail

repo_url="${VIS_REPO_URL:-https://github.com/Blockether/vis.git}"
dest="${VIS_SOURCE_DIR:-$HOME/.vis/sourcecode}"
branch="${VIS_REPO_BRANCH:-}"
local_bin_dir="${VIS_LOCAL_BIN_DIR:-$HOME/.local/bin}"
fork_mode="${VIS_FORK:-false}"
fork_source="${VIS_FORK_SOURCE:-Blockether/vis}"
fork_owner="${VIS_FORK_OWNER:-}"
fork_name="${VIS_FORK_NAME:-}"
upstream_url=""
vis_link="$local_bin_dir/vis"

usage() {
  cat <<EOF
Usage: bin/install-source [--dest PATH] [--repo URL] [--branch NAME]
                          [--fork] [--fork-source OWNER/REPO]
                          [--fork-owner OWNER_OR_ORG] [--fork-name NAME]

Checks for Java, Clojure CLI, and git, then clones Vis to:
  $dest

It also symlinks the launcher to:
  $vis_link

Environment overrides:
  VIS_SOURCE_DIR     checkout path (default: ~/.vis/sourcecode)
  VIS_LOCAL_BIN_DIR  symlink dir (default: ~/.local/bin)
  VIS_REPO_URL       git remote (default: $repo_url)
  VIS_REPO_BRANCH    branch/tag to clone or update
  VIS_FORK           true to create/clone a GitHub fork with gh
  VIS_FORK_SOURCE    source repo for --fork (default: Blockether/vis)
  VIS_FORK_OWNER     fork owner/org for --fork (default: authenticated user)
  VIS_FORK_NAME      fork repo name for --fork (default: source repo name)
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dest)
      [[ $# -ge 2 ]] || { echo "vis install: --dest requires a path" >&2; exit 2; }
      dest="$2"
      shift 2
      ;;
    --repo)
      [[ $# -ge 2 ]] || { echo "vis install: --repo requires a URL" >&2; exit 2; }
      repo_url="$2"
      shift 2
      ;;
    --branch)
      [[ $# -ge 2 ]] || { echo "vis install: --branch requires a name" >&2; exit 2; }
      branch="$2"
      shift 2
      ;;
    --fork)
      fork_mode="true"
      shift
      ;;
    --fork-source)
      [[ $# -ge 2 ]] || { echo "vis install: --fork-source requires OWNER/REPO" >&2; exit 2; }
      fork_source="$2"
      shift 2
      ;;
    --fork-owner)
      [[ $# -ge 2 ]] || { echo "vis install: --fork-owner requires an owner or org" >&2; exit 2; }
      fork_owner="$2"
      shift 2
      ;;
    --fork-name)
      [[ $# -ge 2 ]] || { echo "vis install: --fork-name requires a repo name" >&2; exit 2; }
      fork_name="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "vis install: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

is_fork_mode() {
  [[ "$fork_mode" == "true" || "$fork_mode" == "1" || "$fork_mode" == "yes" ]]
}

normalize_github_slug() {
  local raw="$1"
  raw="${raw#https://github.com/}"
  raw="${raw#http://github.com/}"
  raw="${raw#git@github.com:}"
  raw="${raw%.git}"
  raw="${raw#/}"
  if [[ "$raw" != */* || "$raw" == */*/* ]]; then
    echo "vis install: expected a GitHub repo as OWNER/REPO, got: $1" >&2
    exit 2
  fi
  printf '%s' "$raw"
}

github_repo_url() {
  local slug="$1"
  local protocol="${VIS_GH_PROTOCOL:-}"
  if [[ -z "$protocol" ]]; then
    protocol="$(gh config get git_protocol -h github.com 2>/dev/null || true)"
  fi
  if [[ "$protocol" == "ssh" ]]; then
    printf 'git@github.com:%s.git' "$slug"
  else
    printf 'https://github.com/%s.git' "$slug"
  fi
}

ensure_github_fork() {
  gh auth status -h github.com >/dev/null 2>&1 || {
    echo "vis install: GitHub CLI is not authenticated. Run: gh auth login" >&2
    exit 1
  }

  local source_slug login owner name fork_slug
  source_slug="$(normalize_github_slug "$fork_source")"
  login="$(gh api user --jq .login)"
  owner="${fork_owner:-$login}"
  name="${fork_name:-${source_slug##*/}}"
  fork_slug="$owner/$name"

  if gh repo view "$fork_slug" >/dev/null 2>&1; then
    echo "vis install: using existing GitHub fork: $fork_slug"
  else
    echo "vis install: creating GitHub fork: $source_slug -> $fork_slug"
    local args=(repo fork "$source_slug")
    [[ -n "$fork_name" ]] && args+=(--fork-name "$fork_name")
    [[ -n "$fork_owner" && "$fork_owner" != "$login" ]] && args+=(--org "$fork_owner")
    gh "${args[@]}"
  fi

  repo_url="$(github_repo_url "$fork_slug")"
  upstream_url="$(github_repo_url "$source_slug")"
}

missing=()
required=(java clojure git)
if is_fork_mode; then
  required+=(gh)
fi
for cmd in "${required[@]}"; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    missing+=("$cmd")
  fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
  echo "vis install: missing required command(s): ${missing[*]}" >&2
  echo "" >&2
  echo "Install Java 21+, the Clojure CLI, git, and gh when using --fork; then rerun this script." >&2
  echo "macOS/Homebrew example:" >&2
  echo "  brew install zulu clojure/tools/clojure git gh" >&2
  echo "" >&2
  echo "Linux packages vary by distro; verify with:" >&2
  echo "  java -version" >&2
  echo "  clojure -Sdescribe" >&2
  exit 1
fi

if ! java -version >/dev/null 2>&1; then
  echo "vis install: java exists but failed to run: java -version" >&2
  exit 1
fi

if ! clojure -Sdescribe >/dev/null 2>&1; then
  echo "vis install: clojure exists but failed to run: clojure -Sdescribe" >&2
  echo "vis install: install the official Clojure CLI, not only a standalone clojure.jar." >&2
  exit 1
fi

if is_fork_mode; then
  ensure_github_fork
fi

mkdir -p "$(dirname "$dest")"

if [[ -e "$dest" && ! -d "$dest/.git" ]]; then
  echo "vis install: destination exists but is not a git checkout: $dest" >&2
  echo "vis install: move it aside or choose another --dest." >&2
  exit 1
fi

if [[ ! -d "$dest/.git" ]]; then
  echo "vis install: cloning $repo_url -> $dest"
  if [[ -n "$branch" ]]; then
    git clone --branch "$branch" "$repo_url" "$dest"
  else
    git clone "$repo_url" "$dest"
  fi
else
  echo "vis install: updating existing checkout: $dest"
  git -C "$dest" remote set-url origin "$repo_url"
  git -C "$dest" fetch --prune origin
  if [[ -n "$branch" ]]; then
    git -C "$dest" checkout "$branch"
    git -C "$dest" pull --ff-only origin "$branch"
  else
    current_branch="$(git -C "$dest" branch --show-current || true)"
    if [[ -n "$current_branch" ]]; then
      git -C "$dest" pull --ff-only origin "$current_branch"
    else
      echo "vis install: checkout is detached; fetched origin but did not switch branches." >&2
    fi
  fi
fi

if [[ -n "$upstream_url" ]]; then
  if git -C "$dest" remote get-url upstream >/dev/null 2>&1; then
    git -C "$dest" remote set-url upstream "$upstream_url"
  else
    git -C "$dest" remote add upstream "$upstream_url"
  fi
  echo "vis install: upstream remote -> $upstream_url"
fi

mkdir -p "$local_bin_dir"
if [[ -e "$vis_link" && ! -L "$vis_link" ]]; then
  echo "vis install: not replacing existing non-symlink: $vis_link" >&2
  echo "vis install: move it aside, or run directly: $dest/bin/vis" >&2
else
  ln -sfn "$dest/bin/vis" "$vis_link"
  echo "vis install: linked $vis_link -> $dest/bin/vis"
fi

cat <<EOF

vis install: source checkout ready:
  $dest

Try:
  $vis_link help
  $vis_link doctor
EOF

case ":$PATH:" in
  *":$local_bin_dir:"*) ;;
  *)
    cat <<EOF

Add Vis to PATH if your shell does not already include ~/.local/bin:
  echo 'export PATH="$local_bin_dir:\$PATH"' >> ~/.zshrc
EOF
    ;;
esac
