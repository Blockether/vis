#!/usr/bin/env bash
# Vis CLI launcher.
#
# Wrapper around `clojure -M:vis` with automatic CRaC restore when the
# current JVM supports CRaC. Missing or stale images are bootstrapped
# before Vis loads extensions or starts TUI/channel resources.
#
# Install:
#   1. Clone the repo.
#   2. Add the repo's bin/ dir to your PATH, e.g.:
#        echo 'export PATH="$HOME/path/to/vis/bin:$PATH"' >> ~/.zshrc
#      (or symlink: ln -s "$PWD/bin/vis" /usr/local/bin/vis)
#   3. Run `vis help` to confirm.
#
# This script resolves Clojure deps from the repo root that contains
# THIS script, but preserves the user's invocation directory as the
# JVM `user.dir`. Vis runtime git/environment context must describe
# where the user ran `vis`, not ~/.vis/sourcecode.

set -euo pipefail

invocation_cwd="$PWD"

# Resolve the directory of this script, following symlinks.
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
bin_dir="$(cd -P "$(dirname "$src")" && pwd)"
repo_root="$(cd -P "$bin_dir/.." && pwd)"

cd "$repo_root"

measure_enabled() {
  case "${VIS_MEASURE:-0}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

measure_now_ms() {
  perl -MTime::HiRes=time -e 'printf "%.3f", time() * 1000'
}

measure_log_since() {
  local label="$1"
  local start_ms="$2"
  if measure_enabled; then
    local end_ms elapsed_ms
    end_ms="$(measure_now_ms)"
    elapsed_ms="$(awk -v end="$end_ms" -v start="$start_ms" 'BEGIN { printf "%.1f", end - start }')"
    printf '[vis measure] shell:%s %s ms\n' "$label" "$elapsed_ms" >&2
  fi
}

measure_log() {
  if measure_enabled; then
    printf '[vis measure] shell:%s\n' "$1" >&2
  fi
}

edn_escape_string() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

extension_dep_symbol() {
  local scope="$1"
  local name="$2"
  name="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//')"
  [[ -n "$name" ]] || name="extension"
  printf 'vis-user-extension.%s/%s' "$scope" "$name"
}

collect_user_extension_sdeps() {
  local roots=("project:$invocation_cwd/.vis/vis-extensions" "global:$HOME/.vis/vis-extensions")
  local root_spec root_scope root deps_file ext_dir ext_name dep_sym escaped
  local -a entries=()
  shopt -s nullglob
  for root_spec in "${roots[@]}"; do
    root_scope="${root_spec%%:*}"
    root="${root_spec#*:}"
    for deps_file in "$root"/*/deps.edn; do
      [[ -f "$deps_file" ]] || continue
      ext_dir="$(cd -P "$(dirname "$deps_file")" && pwd)"
      ext_name="$(basename "$ext_dir")"
      dep_sym="$(extension_dep_symbol "$root_scope" "$ext_name")"
      escaped="$(edn_escape_string "$ext_dir")"
      entries+=("$dep_sym {:local/root \"$escaped\"}")
    done
  done
  shopt -u nullglob
  if (( ${#entries[@]} > 0 )); then
    printf '{:deps {'
    printf '%s ' "${entries[@]}"
    printf '}}'
  fi
}

user_extension_sdeps="$(collect_user_extension_sdeps)"
vis_extension_sdeps=()
if [[ -n "$user_extension_sdeps" ]]; then
  vis_extension_sdeps=(-Sdeps "$user_extension_sdeps")
  measure_log "user extension deps enabled"
fi

run_measured_or_exec() {
  local label="$1"
  shift
  if measure_enabled; then
    local start_ms code
    start_ms="$(measure_now_ms)"
    "$@"
    code=$?
    measure_log_since "$label exit=$code" "$start_ms"
    exit "$code"
  else
    exec "$@"
  fi
}

args=()
for arg in "$@"; do
  if [[ "$arg" == "--measure" ]]; then
    export VIS_MEASURE=1
  else
    args+=("$arg")
  fi
done
set -- "${args[@]}"

crac_disabled() {
  case "${VIS_CRAC:-auto}" in
    0|false|FALSE|no|NO|off|OFF|disable|disabled) return 0 ;;
    *) return 1 ;;
  esac
}

crac_forced() {
  case "${VIS_CRAC:-auto}" in
    1|true|TRUE|yes|YES|on|ON|force|FORCE) return 0 ;;
    *) return 1 ;;
  esac
}

crac_sim_allowed() {
  case "${VIS_CRAC_SIM:-0}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

crac_supported() {
  crac_forced && return 0
  if [[ "$(uname -s)" != "Linux" ]] && ! crac_sim_allowed; then
    return 1
  fi
  "${JAVA_CMD:-java}" -XX:+PrintFlagsFinal -version 2>&1 | grep -Eq 'CRaC(CheckpointTo|RestoreFrom)'
}

crac_downloaded_java_hint() {
  find "$HOME/.vis/jdks" -path '*crac*/bin/java' -type f -print -quit 2>/dev/null || true
}

print_crac_unavailable_hint() {
  local detected_java
  detected_java="$(crac_downloaded_java_hint)"
  echo "vis: CRaC unavailable on this JVM; falling back to cold Clojure startup." >&2
  echo "vis: CRaC can make startup faster, but you must run Vis with a CRaC-capable JDK." >&2
  if [[ -n "$detected_java" ]]; then
    echo "vis: detected a downloaded CRaC JDK:" >&2
    echo "     $detected_java" >&2
    echo "vis: on macOS this is simulation-only; use VIS_CRAC_SIM=1 only to validate hooks, not for speed." >&2
  else
    echo "vis: install Azul Zulu CRaC JDK. SDKMAN may not list CRaC builds; Azul's direct tarballs do." >&2
  fi
  echo "vis: note: macOS/Windows CRaC builds are simulation engines for validation; real checkpoint/restore speedup requires Linux x64/aarch64." >&2
  echo "vis: set VIS_CRAC=0 to silence this hint." >&2
}

crac_rebuild_requested() {
  case "${VIS_CRAC_REBUILD:-0}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

crac_image_has_entries() {
  local dir="$1"
  [[ -d "$dir" ]] && [[ -n "$(find "$dir" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]]
}

crac_stat_file() {
  local path="$1"
  if stat -f '%N|%z|%m' "$path" >/dev/null 2>&1; then
    stat -f '%N|%z|%m' "$path"
  else
    stat -c '%n|%s|%Y' "$path"
  fi
}

crac_sha256() {
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | awk '{print $1}'
  else
    sha256sum | awk '{print $1}'
  fi
}

crac_fingerprint() {
  {
    for path in deps.edn VERSION bin/vis; do
      [[ -f "$path" ]] && crac_stat_file "$path"
    done
    find src extensions \
      -path '*/target' -prune -o \
      -path '*/.cpcache' -prune -o \
      -type f \( -name '*.clj' -o -name '*.cljc' -o -name '*.cljs' -o -name '*.edn' -o -name '*.sql' \) \
      -print 2>/dev/null | sort | while IFS= read -r path; do
        crac_stat_file "$path"
      done
  } | crac_sha256
}

if crac_disabled; then
  measure_log "crac disabled by VIS_CRAC=$VIS_CRAC"
elif [[ -n "$user_extension_sdeps" ]]; then
  measure_log "crac disabled because user extension classpath is dynamic"
else
  crac_probe_start_ms="$(measure_now_ms)"
  if crac_supported; then
    measure_log_since "crac support probe: supported" "$crac_probe_start_ms"
    image_dir="${VIS_CRAC_IMAGE_DIR:-$HOME/.vis/crac/bin-vis}"
    stamp_file="${image_dir%/}.fingerprint"
    fingerprint_start_ms="$(measure_now_ms)"
    fingerprint="$(crac_fingerprint)"
    measure_log_since "crac fingerprint" "$fingerprint_start_ms"
    rebuild_reason=""
    if crac_rebuild_requested; then
      rebuild_reason="VIS_CRAC_REBUILD=1"
    elif ! crac_image_has_entries "$image_dir"; then
      rebuild_reason="missing image"
    elif [[ ! -f "$stamp_file" ]]; then
      rebuild_reason="missing fingerprint"
    elif [[ "$(<"$stamp_file")" != "$fingerprint" ]]; then
      rebuild_reason="stale fingerprint"
    fi
    if [[ -n "$rebuild_reason" ]]; then
      rm -rf "$image_dir"
      mkdir -p "$image_dir"
      echo "vis: building CRaC image at $image_dir ($rebuild_reason)" >&2
      checkpoint_start_ms="$(measure_now_ms)"
      if ! clojure -J-XX:+IgnoreUnrecognizedVMOptions "-J-Duser.dir=$invocation_cwd" -J-XX:CRaCCheckpointTo="$image_dir" -M:vis-crac-bootstrap; then
        measure_log_since "crac checkpoint failed" "$checkpoint_start_ms"
        echo "vis: CRaC bootstrap failed; falling back to cold Clojure startup. Set VIS_CRAC=0 to disable." >&2
        run_measured_or_exec "process cold clojure -M:vis" clojure "-J-Duser.dir=$invocation_cwd" "${vis_extension_sdeps[@]}" -M:vis "$@"
      fi
      measure_log_since "crac checkpoint" "$checkpoint_start_ms"
      if ! crac_image_has_entries "$image_dir"; then
        echo "vis: CRaC bootstrap produced no image; falling back to cold Clojure startup." >&2
        run_measured_or_exec "process cold clojure -M:vis" clojure "-J-Duser.dir=$invocation_cwd" "${vis_extension_sdeps[@]}" -M:vis "$@"
      fi
      printf '%s\n' "$fingerprint" > "$stamp_file"
    else
      measure_log "crac image fresh: $image_dir"
    fi
    measure_log "exec crac restore: $image_dir"
    run_measured_or_exec "process crac restore" clojure -J-XX:+IgnoreUnrecognizedVMOptions "-J-Duser.dir=$invocation_cwd" -J-XX:CRaCRestoreFrom="$image_dir" -M:vis "$@"
  else
    measure_log_since "crac support probe: unsupported" "$crac_probe_start_ms"
    if crac_rebuild_requested || crac_forced || measure_enabled; then
      print_crac_unavailable_hint
    fi
  fi
fi

measure_log "exec cold clojure -M:vis"
run_measured_or_exec "process cold clojure -M:vis" clojure "-J-Duser.dir=$invocation_cwd" "${vis_extension_sdeps[@]}" -M:vis "$@"
