#!/usr/bin/env bash
# Vis CLI launcher.
#
# Wrapper around `clojure -M:vis`.
#
# Install:
#   1. Clone the repo.
#   2. Add the repo's bin/ dir to your PATH, e.g.:
#        echo 'export PATH="$HOME/path/to/vis/bin:$PATH"' >> ~/.zshrc
#      (or symlink: ln -s "$PWD/bin/vis" /usr/local/bin/vis)
#   3. Run `vis help` to confirm.
#
# This script resolves Clojure deps from the repo root that contains
# THIS script, but preserves the user's invocation directory as the
# JVM `user.dir`. Vis runtime git/environment context must describe
# where the user ran `vis`, not ~/.vis/sourcecode.

set -euo pipefail

invocation_cwd="$PWD"

# Resolve the directory of this script, following symlinks.
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
bin_dir="$(cd -P "$(dirname "$src")" && pwd)"
repo_root="$(cd -P "$bin_dir/.." && pwd)"

cd "$repo_root"

measure_enabled() {
  case "${VIS_MEASURE:-0}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

measure_now_ms() {
  perl -MTime::HiRes=time -e 'printf "%.3f", time() * 1000'
}

measure_log_since() {
  local label="$1"
  local start_ms="$2"
  if measure_enabled; then
    local end_ms elapsed_ms
    end_ms="$(measure_now_ms)"
    elapsed_ms="$(awk -v end="$end_ms" -v start="$start_ms" 'BEGIN { printf "%.1f", end - start }')"
    printf '[vis measure] shell:%s %s ms\n' "$label" "$elapsed_ms" >&2
  fi
}

measure_log() {
  if measure_enabled; then
    printf '[vis measure] shell:%s\n' "$1" >&2
  fi
}

edn_escape_string() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

extension_dep_symbol() {
  local scope="$1"
  local name="$2"
  name="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//')"
  [[ -n "$name" ]] || name="extension"
  printf 'vis-user-extension.%s/%s' "$scope" "$name"
}

collect_user_extension_sdeps() {
  local roots=("project:$invocation_cwd/.vis/vis-extensions" "global:$HOME/.vis/vis-extensions")
  local root_spec root_scope root deps_file ext_dir ext_name dep_sym escaped
  local -a entries=()
  shopt -s nullglob
  for root_spec in "${roots[@]}"; do
    root_scope="${root_spec%%:*}"
    root="${root_spec#*:}"
    for deps_file in "$root"/*/deps.edn; do
      [[ -f "$deps_file" ]] || continue
      ext_dir="$(cd -P "$(dirname "$deps_file")" && pwd)"
      ext_name="$(basename "$ext_dir")"
      dep_sym="$(extension_dep_symbol "$root_scope" "$ext_name")"
      escaped="$(edn_escape_string "$ext_dir")"
      entries+=("$dep_sym {:local/root \"$escaped\"}")
    done
  done
  shopt -u nullglob
  if (( ${#entries[@]} > 0 )); then
    printf '{:deps {'
    printf '%s ' "${entries[@]}"
    printf '}}'
  fi
}

user_extension_sdeps="$(collect_user_extension_sdeps)"
vis_extension_sdeps=()
if [[ -n "$user_extension_sdeps" ]]; then
  vis_extension_sdeps=(-Sdeps "$user_extension_sdeps")
  measure_log "user extension deps enabled"
fi

run_measured_or_exec() {
  local label="$1"
  shift
  if measure_enabled; then
    local start_ms code
    start_ms="$(measure_now_ms)"
    "$@"
    code=$?
    measure_log_since "$label exit=$code" "$start_ms"
    exit "$code"
  else
    exec "$@"
  fi
}

args=()
for arg in "$@"; do
  if [[ "$arg" == "--measure" ]]; then
    export VIS_MEASURE=1
  else
    args+=("$arg")
  fi
done
if (( ${#args[@]} > 0 )); then
  set -- "${args[@]}"
else
  set --
fi

# svar SSE per-line trace. Off by default. Set VIS_STREAM_TRACE=1 (or
# true/yes/on) to flip `-Dsvar.stream.trace=true` on this JVM; the svar
# SSE reader then emits `::stream-line-trace` log entries every N lines
# OR whenever the inter-line gap >= STREAM_LINE_TRACE_GAP_MS. Use to
# diagnose stuck `ask-code!` streams (silent server reasoning vs. ping
# storms vs. real model deltas) without rebuilding svar.
stream_trace_jvm_opts=()
case "${VIS_STREAM_TRACE:-0}" in
  1|true|TRUE|yes|YES|on|ON)
    stream_trace_jvm_opts=("-J-Dsvar.stream.trace=true")
    measure_log "svar stream trace enabled"
    ;;
esac

measure_log "exec cold clojure -M:vis"
if (( ${#vis_extension_sdeps[@]} > 0 )); then
  run_measured_or_exec "process cold clojure -M:vis" clojure "-J-Duser.dir=$invocation_cwd" "${stream_trace_jvm_opts[@]}" "${vis_extension_sdeps[@]}" -M:vis "$@"
else
  run_measured_or_exec "process cold clojure -M:vis" clojure "-J-Duser.dir=$invocation_cwd" "${stream_trace_jvm_opts[@]}" -M:vis "$@"
fi
