#!/usr/bin/env bash
# Vis CLI launcher.
#
# Wrapper around `clojure -M:vis`.
#
# Install:
#   1. Clone the repo.
#   2. Add the repo's bin/ dir to your PATH, e.g.:
#        echo 'export PATH="$HOME/path/to/vis/bin:$PATH"' >> ~/.zshrc
#      (or symlink: ln -s "$PWD/bin/vis" /usr/local/bin/vis)
#   3. Run `vis help` to confirm.
#
# This script resolves Clojure deps from the repo root that contains
# THIS script, but preserves the user's invocation directory as the
# JVM `user.dir`. Vis runtime git/environment context must describe
# where the user ran `vis`, not ~/.vis/sourcecode.

set -euo pipefail

invocation_cwd="$PWD"

# Resolve the directory of this script, following symlinks.
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
bin_dir="$(cd -P "$(dirname "$src")" && pwd)"
repo_root="$(cd -P "$bin_dir/.." && pwd)"

# ── Prefer a developer checkout at ~/vis ─────────────────────────────────────
# A managed install symlinks `vis` to ~/.vis/sourcecode, so `vis` would run that
# clone's code even when you're actively hacking on ~/vis. If a dev checkout
# exists at ~/vis (or $VIS_DEV_CHECKOUT) and we were launched from a DIFFERENT
# repo root, hand off to it so your working-tree edits take effect with no resync.
# The guard env var breaks the re-exec loop (the handoff target is ~/vis itself).
# Set VIS_NO_DEV_CHECKOUT=1 to force the managed/installed build instead.
dev_checkout="${VIS_DEV_CHECKOUT:-$HOME/vis}"
if [[ -z "${VIS_NO_DEV_CHECKOUT:-}" \
      && "$repo_root" != "$dev_checkout" \
      && -f "$dev_checkout/bin/vis" \
      && -f "$dev_checkout/deps.edn" ]]; then
  export VIS_NO_DEV_CHECKOUT=1
  exec "$dev_checkout/bin/vis" "$@"
fi

cd "$repo_root"

measure_enabled() {
  case "${VIS_MEASURE:-0}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

measure_now_ms() {
  perl -MTime::HiRes=time -e 'printf "%.3f", time() * 1000'
}

measure_log_since() {
  local label="$1"
  local start_ms="$2"
  if measure_enabled; then
    local end_ms elapsed_ms
    end_ms="$(measure_now_ms)"
    elapsed_ms="$(awk -v end="$end_ms" -v start="$start_ms" 'BEGIN { printf "%.1f", end - start }')"
    printf '[vis measure] shell:%s %s ms\n' "$label" "$elapsed_ms" >&2
  fi
}

measure_log() {
  if measure_enabled; then
    printf '[vis measure] shell:%s\n' "$1" >&2
  fi
}

edn_escape_string() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

extension_dep_symbol() {
  local scope="$1"
  local name="$2"
  name="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//')"
  [[ -n "$name" ]] || name="extension"
  printf 'vis-user-extension.%s/%s' "$scope" "$name"
}

collect_user_extension_sdeps() {
  local roots=("project:$invocation_cwd/.vis/vis-extensions" "global:$HOME/.vis/vis-extensions")
  local root_spec root_scope root deps_file ext_dir ext_name dep_sym escaped
  local -a entries=()
  shopt -s nullglob
  for root_spec in "${roots[@]}"; do
    root_scope="${root_spec%%:*}"
    root="${root_spec#*:}"
    for deps_file in "$root"/*/deps.edn; do
      [[ -f "$deps_file" ]] || continue
      ext_dir="$(cd -P "$(dirname "$deps_file")" && pwd)"
      ext_name="$(basename "$ext_dir")"
      dep_sym="$(extension_dep_symbol "$root_scope" "$ext_name")"
      escaped="$(edn_escape_string "$ext_dir")"
      entries+=("$dep_sym {:local/root \"$escaped\"}")
    done
  done
  shopt -u nullglob
  if (( ${#entries[@]} > 0 )); then
    printf '{:deps {'
    printf '%s ' "${entries[@]}"
    printf '}}'
  fi
}

user_extension_sdeps="$(collect_user_extension_sdeps)"
vis_extension_sdeps=()
if [[ -n "$user_extension_sdeps" ]]; then
  vis_extension_sdeps=(-Sdeps "$user_extension_sdeps")
  measure_log "user extension deps enabled"
fi

run_measured_or_exec() {
  local label="$1"
  shift
  if measure_enabled; then
    local start_ms code
    start_ms="$(measure_now_ms)"
    "$@"
    code=$?
    measure_log_since "$label exit=$code" "$start_ms"
    exit "$code"
  else
    exec "$@"
  fi
}

# Strip launcher-only flags before they reach the app. They pick which build
# to run, overriding the auto precedence (native > live source; the uberjar is
# never auto-selected):
#   --source   force LIVE SOURCE (clojure -M:vis) — your working-tree edits
#   --jar      force the AOT uberjar (target/vis.jar)
#   --native   force the native binary (target/vis[.exe])
#   --jvm      back-compat alias for --source
#   --jfr      profile with JFR: exports VIS_JFR=1 so the client (TUI/web) AND
#              the detached gateway daemon it spawns EACH record their own
#              ~/.vis/vis-<role>-<pid>-<ts>.jfr (works on source, jar, AND the
#              native binary — built with --enable-monitoring=jfr), dumped on exit.
dist=""   # "" = auto; else "source" | "jar" | "native"
jfr=0
args=()
for arg in "$@"; do
  case "$arg" in
    --measure)        export VIS_MEASURE=1 ;;
    --source|--jvm)   dist="source" ;;
    --jar)            dist="jar" ;;
    --native)         dist="native" ;;
    --jfr)            jfr=1 ;;
    *)                args+=("$arg") ;;
  esac
done
if (( ${#args[@]} > 0 )); then
  set -- "${args[@]}"
else
  set --
fi

# ── --jfr: Java Flight Recorder profiling ─────────────────────────────
# Export VIS_JFR=1 so EVERY vis process this launch spawns records itself: the
# client (TUI / web / one-shot) AND the detached gateway daemon (which inherits
# the env) each start their OWN role-tagged recording IN-PROCESS (see
# internal.jfr/maybe-start!). That yields two SEPARATE readings to compare when
# a client seems to wait on the gateway:
#   ~/.vis/vis-client-<pid>-<ts>.jfr   and   ~/.vis/vis-gateway-<pid>-<ts>.jfr
# Unlike a JVM-launch -XX:StartFlightRecording (client-only, dies on native),
# this covers the daemon too and works identically on source, jar, and the
# native binary (built with --enable-monitoring=jfr — see native-image.properties).
if (( jfr )); then
  export VIS_JFR=1
  mkdir -p "$HOME/.vis" 2>/dev/null || true
  echo "vis: JFR profiling on (VIS_JFR=1) → ~/.vis/vis-{client,gateway}-<pid>-<ts>.jfr, dumped on exit." >&2
  echo "vis:   snapshot mid-run: jcmd <pid> JFR.dump name=vis-<role>" >&2
  echo "vis:   analyze:  jfr print --events jdk.ExecutionSample ~/.vis/vis-gateway-*.jfr" >&2
fi

# ── Managed install + self-update ───────────────────────────────────────────
# `vis update` maintains ~/.vis/install as a "registry"-backed install that the
# launcher prefers over the repo build:
#   vis update                       (in a git checkout) update SOURCE via git pull
#   vis update --rebuild             ... and BUILD the native from that source
#   vis update --native              ... and DOWNLOAD the latest release native
#   vis update <version>|latest
#                                    pull a NATIVE binary from a GitHub release
#   vis update <git-sha>             switch to JVM source pinned to that commit
# VIS_HOME overrides the location (default ~/.vis).
vis_home="${VIS_HOME:-$HOME/.vis}"
vis_install_dir="$vis_home/install"
vis_repo_slug="Blockether/vis"

vis_platform_asset() {
  # Release asset basename for THIS host (no -with-assets suffix).
  local os arch ext=""
  case "$(uname -s)" in
    Darwin)                       os=macos ;;
    Linux)                        os=linux ;;
    MINGW*|MSYS*|CYGWIN*|Windows*) os=windows; ext=".exe" ;;
    *) echo "vis update: unsupported OS $(uname -s)" >&2; return 1 ;;
  esac
  case "$(uname -m)" in
    arm64|aarch64) arch=arm64 ;;
    x86_64|amd64)  arch=x64 ;;
    *) echo "vis update: unsupported arch $(uname -m)" >&2; return 1 ;;
  esac
  printf 'vis-%s-%s%s' "$os" "$arch" "$ext"
}

vis_do_update() {
  local target="" fetch_native=0 rebuild=0 a
  for a in "$@"; do
    case "$a" in
      --native)      fetch_native=1 ;;  # also DOWNLOAD the latest release binary
      --rebuild)     rebuild=1 ;;        # also BUILD the native from pulled source
      *)             target="$a" ;;
    esac
  done
  mkdir -p "$vis_install_dir"

  # A git SHA → JVM source mode (runs the exact commit on the JVM, no native).
  if [[ "$target" =~ ^[0-9a-fA-F]{7,40}$ ]]; then
    command -v git >/dev/null     || { echo "vis update <sha> needs git on PATH" >&2; exit 1; }
    command -v clojure >/dev/null || { echo "vis update <sha> runs on the JVM and needs the Clojure CLI" >&2; exit 1; }
    local src="$vis_install_dir/src"
    [[ -d "$src/.git" ]] || git clone --filter=blob:none "https://github.com/$vis_repo_slug.git" "$src" || exit 1
    git -C "$src" fetch --filter=blob:none origin || exit 1
    git -C "$src" checkout --force "$target" || exit 1
    printf 'jvm-sha' > "$vis_install_dir/mode"
    printf '%s' "$target" > "$vis_install_dir/sha"
    echo "vis: now on JVM source @ $target  ($src)"
    echo "     run 'vis update latest' to return to the native binary."
    exit 0
  fi

  # Bare `vis update` (no version/sha) from a git source checkout updates the
  # SOURCE via git pull. By default it does NOT touch any binary. Opt in with:
  #   --rebuild  → BUILD the native from the freshly pulled source (slow)
  #   --native   → DOWNLOAD the latest release native (falls through below)
  # (`vis update latest|<version>` is an explicit release native; `<sha>` above
  #  is the jvm-sha pin.)
  if [[ -z "$target" && -d "$repo_root/.git" ]]; then
    command -v git >/dev/null || { echo "vis update needs git on PATH to update source" >&2; exit 1; }
    echo "vis: updating source at $repo_root (git fetch + pull --ff-only)"
    git -C "$repo_root" fetch --tags origin || exit 1
    git -C "$repo_root" pull --ff-only || {
      echo "vis update: 'git pull --ff-only' failed — commit/stash local changes or reconcile diverged history, then retry." >&2
      exit 1
    }
    if (( rebuild )); then
      command -v clojure >/dev/null || { echo "vis update --rebuild needs the Clojure CLI" >&2; exit 1; }
      echo "vis: building native binary from updated source ('clojure -T:build native')"
      ( cd "$repo_root" && clojure -T:build native ) || exit 1
      echo "vis: source updated + native binary built from source."
      exit 0
    elif (( fetch_native )); then
      # Source is current; now pull the latest RELEASE native too (handled by the
      # release-download block below, with target left empty → 'latest').
      echo "vis: source updated; fetching the latest release native binary…"
    else
      echo "vis: source updated (live-source runs the new code next launch from"
      echo "     inside the repo). For a fast binary: 'vis update --rebuild' (build"
      echo "     from this source) or 'vis update --native' (latest release)."
      exit 0
    fi
  fi

  # Otherwise a release version (or explicit 'latest', or the --native fall-through
  # above) → download a native binary from a GitHub release.
  command -v curl >/dev/null || { echo "vis update needs curl on PATH" >&2; exit 1; }
  local asset api dl
  asset="$(vis_platform_asset)" || exit 1
  if [[ -z "$target" || "$target" == latest ]]; then
    api="https://api.github.com/repos/$vis_repo_slug/releases/latest"
  else
    api="https://api.github.com/repos/$vis_repo_slug/releases/tags/$target"
  fi
  echo "vis: resolving $asset from $api"
  dl="$(curl -fsSL "$api" | grep -o "https://[^\"]*/${asset}" | head -1)" || true
  [[ -n "$dl" ]] || { echo "vis update: release has no asset '$asset'" >&2; exit 1; }
  echo "vis: downloading $dl"
  curl -fSL "$dl" -o "$vis_install_dir/native.tmp" || exit 1
  chmod +x "$vis_install_dir/native.tmp"
  mv -f "$vis_install_dir/native.tmp" "$vis_install_dir/native"
  printf 'native' > "$vis_install_dir/mode"
  echo "vis: updated to native $asset (~$(du -h "$vis_install_dir/native" | cut -f1))."
  exit 0
}

# Self-compilation subcommands: build vis itself from source via the
# tools.build tasks in build.clj (repo root), instead of launching the agent.
# Cross-platform: this bash path covers Linux/macOS and Git-Bash/WSL on
# Windows; bin/vis.cmd mirrors it for native Windows cmd.
#   vis native  -> BOTH the uberjar (target/vis.jar) AND the native binary
#                  (target/vis, target/vis.exe on Windows), in one command
#   vis uber    -> just the all-in-one AOT uberjar (target/vis.jar)
case "${1:-}" in
  native|uber)
    measure_log "exec clojure -T:build $1"
    run_measured_or_exec "build $1" clojure -T:build "$1"
    ;;
  update)
    shift
    vis_do_update "$@"
    ;;
esac

# Repo build artifacts (self-contained → exec from the user's ORIGINAL cwd so
# `vis` behaves the same whether or not you're inside the repo).
native_bin="$repo_root/target/vis"
[[ -x "$native_bin" ]] || native_bin="$repo_root/target/vis.exe"
uber_jar="$repo_root/target/vis.jar"

# ── Explicit build override (--source / --jar / --native) wins over auto. ─────
case "$dist" in
  source) measure_log "--source → live source" ;;   # fall through to live source below
  jar)
    if [[ -f "$uber_jar" ]]; then
      measure_log "--jar → $uber_jar"; cd "$invocation_cwd"
      run_measured_or_exec "process java -jar uberjar" java "-Duser.dir=$invocation_cwd" "${jfr_java_opts[@]}" -jar "$uber_jar" "$@"
    else
      echo "vis: --jar requested but $uber_jar is missing (build it with 'vis uber'); using live source." >&2
    fi ;;
  native)
    nb="$native_bin"; [[ -x "$nb" ]] || nb="$vis_install_dir/native"
    if [[ -x "$nb" ]]; then
      measure_log "--native → $nb"; cd "$invocation_cwd"
      run_measured_or_exec "process native binary" "$nb" "$@"
    else
      echo "vis: --native requested but no native binary found (build with 'vis native'); using live source." >&2
    fi ;;
esac

# ── Auto precedence (no override): NATIVE if present, else LIVE SOURCE. ───────
# The uberjar is NEVER auto-selected — it silently shadows working-tree edits,
# so it is reachable ONLY via --jar. Inside the repo that holds this launcher we
# skip even the native so a dev's source edits always win (set VIS_PREBUILT=1 to
# run the build in-repo). A managed install (`vis update`) is an explicit global
# choice and still takes precedence when you're outside the repo.
if [[ -z "$dist" ]]; then
  in_repo=0
  case "$invocation_cwd/" in "$repo_root"/*) in_repo=1 ;; esac
  if (( in_repo )) && [[ -z "${VIS_PREBUILT:-}" ]]; then
    measure_log "in-repo invocation → live source (VIS_PREBUILT=1 to use the build)"
  else
    if [[ -f "$vis_install_dir/mode" ]]; then
      case "$(cat "$vis_install_dir/mode" 2>/dev/null)" in
        native)
          if [[ -x "$vis_install_dir/native" ]]; then
            measure_log "exec managed native $vis_install_dir/native"; cd "$invocation_cwd"
            run_measured_or_exec "managed native" "$vis_install_dir/native" "$@"
          fi ;;
        jvm-sha)
          if [[ -d "$vis_install_dir/src" ]]; then
            measure_log "exec managed jvm-sha src"; cd "$vis_install_dir/src"
            run_measured_or_exec "managed jvm-sha" clojure "-J-Duser.dir=$invocation_cwd" ${jfr_clj_opts[@]+"${jfr_clj_opts[@]}"} -M:vis "$@"
          fi ;;
      esac
    fi
    if [[ -x "$native_bin" ]]; then
      measure_log "exec native binary $native_bin"; cd "$invocation_cwd"
      run_measured_or_exec "process native binary" "$native_bin" "$@"
    fi
    # No native binary anywhere for this (non-repo) user — nudge toward the fast
    # native path. The native binary is the shipped distribution; source is slow.
    if [[ -z "${VIS_NO_NATIVE_HINT:-}" && -t 2 ]]; then
      echo "vis: running from JVM source (slow cold start). For fast startup, get the native binary:" >&2
      echo "vis:   'vis update --native'  (download the latest release)   or   'vis native'  (build it)" >&2
      echo "vis:   (set VIS_NO_NATIVE_HINT=1 to silence)" >&2
    fi
  fi
fi

# No prebuilt distribution -> run from live source. svar SSE per-line trace. ON BY DEFAULT - the per-line log is gated
# on `gap-ms >= STREAM_LINE_TRACE_GAP_MS` OR `mod line-count
# STREAM_LINE_TRACE_EVERY_N == 0` so a normal fast-streaming turn
# only logs ~once per 25 lines; cost is negligible while the
# diagnostic value (gap-ms / line-preview / content-acc-len on every
# stuck stream, no rebuild required) is large enough that we want
# it always on for real-user invocations.
#
# Set VIS_STREAM_TRACE=0 (or false/no/off) to suppress.
stream_trace_jvm_opts=("-J-Dsvar.stream.trace=true")
case "${VIS_STREAM_TRACE:-1}" in
  0|false|FALSE|no|NO|off|OFF)
    stream_trace_jvm_opts=()
    measure_log "svar stream trace disabled"
    ;;
  *)
    measure_log "svar stream trace enabled"
    ;;
esac

measure_log "exec cold clojure -M:vis"
if (( ${#vis_extension_sdeps[@]} > 0 )); then
  run_measured_or_exec "process cold clojure -M:vis" clojure "-J-Duser.dir=$invocation_cwd" ${stream_trace_jvm_opts[@]+"${stream_trace_jvm_opts[@]}"} ${jfr_clj_opts[@]+"${jfr_clj_opts[@]}"} "${vis_extension_sdeps[@]}" -M:vis "$@"
else
  run_measured_or_exec "process cold clojure -M:vis" clojure "-J-Duser.dir=$invocation_cwd" ${stream_trace_jvm_opts[@]+"${stream_trace_jvm_opts[@]}"} ${jfr_clj_opts[@]+"${jfr_clj_opts[@]}"} -M:vis "$@"
fi
