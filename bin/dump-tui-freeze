#!/usr/bin/env bash
set -euo pipefail

# Capture diagnostics for a Vis TUI freeze/hang without mutating runtime state.
# Usage:
#   bin/dump-tui-freeze [conversation-prefix-or-uuid] [output-dir]

ref="${1:-}"
out_root="${2:-dumps}"
ts="$(date +%Y%m%d-%H%M%S)"
out_dir="$out_root/vis-freeze-$ts"
mkdir -p "$out_dir"

run() {
  local name="$1"
  shift
  {
    echo '$' "$@"
    "$@"
  } >"$out_dir/$name" 2>&1 || true
}

{
  echo "timestamp=$ts"
  echo "pwd=$(pwd)"
  echo "conversation_ref=$ref"
  echo "user=$(id -un 2>/dev/null || true)"
  echo "uname=$(uname -a 2>/dev/null || true)"
  echo "java=$(java -version 2>&1 | tr '\n' ' ' || true)"
  echo "git_branch=$(git branch --show-current 2>/dev/null || true)"
  echo "git_status_short="
  git status --short 2>/dev/null || true
} >"$out_dir/meta.txt"

run nrepl.txt clj-nrepl-eval --discover-ports
run java-processes.txt bash -lc "ps axww -o pid=,ppid=,stat=,etime=,command= | grep -E 'java|clojure|vis' | grep -v grep"
run listening-ports.txt bash -lc "lsof -nP -iTCP -sTCP:LISTEN | grep -E 'java|COMMAND|7888|nrepl|vis' || true"
run vis-log-tail.txt bash -lc 'for f in "$HOME/.vis/vis.log" "$HOME/.vis/logs/vis.log"; do [ -f "$f" ] && { echo "== $f"; tail -300 "$f"; }; done'

# Candidate Vis JVMs: dev nREPL and TUI JVMs. Keep the pattern broad enough
# for `bin/dev`, `bin/dev terminal-tui`, and `vis channels tui` command lines.
mapfile -t pids < <(ps axww -o pid=,command= \
  | awk '/java/ && /com\.blockether\.vis|clojure\.main -m com\.blockether\.vis|terminal-tui|channels tui/ {print $1}' \
  | sort -u)

{
  printf '%s\n' "${pids[@]}"
} >"$out_dir/candidate-pids.txt"

for pid in "${pids[@]}"; do
  pid_dir="$out_dir/pid-$pid"
  mkdir -p "$pid_dir"
  run "pid-$pid/ps.txt" bash -lc "ps -p '$pid' -o pid,ppid,stat,etime,%cpu,%mem,command"
  run "pid-$pid/jcmd-command-line.txt" jcmd "$pid" VM.command_line
  run "pid-$pid/jcmd-flags.txt" jcmd "$pid" VM.flags
  run "pid-$pid/jcmd-heap-info.txt" jcmd "$pid" GC.heap_info
  for i in 1 2 3; do
    run "pid-$pid/thread-$i.txt" jcmd "$pid" Thread.print -l
    sleep 1
  done

done

# Optional conversation snapshot through the first discovered nREPL in this cwd.
# This is intentionally compact: enough to correlate wall-clock iteration time
# with per-form execution without dumping huge result bodies.
if [[ -n "$ref" ]] && command -v clj-nrepl-eval >/dev/null 2>&1; then
  port="$(clj-nrepl-eval --discover-ports 2>/dev/null | awk '/In current directory/{seen=1} seen && /localhost:[0-9]+/ {sub(/.*localhost:/, ""); sub(/ .*/, ""); print; exit}')"
  if [[ -n "$port" ]]; then
    code="(require '[com.blockether.vis.core :as vis] :reload)
(require '[com.blockether.vis.ext.foundation.transcript :as tr] :reload)
(require '[clojure.pprint :as pp])
(let [db (vis/db-info)
      t (tr/transcript db \"$ref\")
      cid (get-in t [:conversation :id])]
  (letfn [(result-summary [v]
            (cond
              (= :vis/silent v) :vis/silent
              (= :vis/answer v) :vis/answer
              (nil? v) nil
              (string? v) {:type :string :chars (count v) :preview (subs v 0 (min 120 (count v)))}
              (coll? v) {:type (str (type v)) :count (count v)}
              :else {:type (str (type v)) :value (pr-str v)}))
          (text-summary [s]
            (let [s (str s)]
              (if (> (count s) 300)
                {:chars (count s) :preview (subs s 0 300)}
                s)))
          (block-summary [b]
            (when b
              {:idx (:idx b)
               :code (text-summary (:code b))
               :result (result-summary (:result b))
               :duration-ms (:duration-ms b)
               :error (:error b)}))]
    (pp/pprint
      {:resolved cid
     :conversation (:conversation t)
     :turns (mapv (fn [turn]
                    {:id (:id turn)
                     :status (:status turn)
                     :prior-outcome (:prior-outcome turn)
                     :answer? (boolean (:answer turn))
                     :iteration-count (:iteration-count turn)
                     :failure-count (:failure-count turn)
                     :iterations (mapv (fn [it]
                                          {:position (:position it)
                                           :status (:status it)
                                           :duration-ms (:duration-ms it)
                                           :raw-len (:llm-raw-response-length it)
                                           :block-count (count (:blocks it))
                                           :first-block (block-summary (first (:blocks it)))
                                           :last-block (block-summary (last (:blocks it)))})
                                        (:iterations turn))})
                  (:turns t))})))"
    clj-nrepl-eval -p "$port" "$code" >"$out_dir/conversation-summary.edn" 2>&1 || true
  fi
fi

echo "$out_dir"
