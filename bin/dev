#!/usr/bin/env bash
# Vis development launcher.
#
# Starts the project dev nREPL (`clojure -M:test:dev`) and optionally launches
# development entry points. See `clojure -M:dev --help`.

set -euo pipefail

# Resolve the directory of this script, following symlinks.
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
bin_dir="$(cd -P "$(dirname "$src")" && pwd)"
repo_root="$(cd -P "$bin_dir/.." && pwd)"

cd "$repo_root"

measure_enabled() {
  case "${VIS_MEASURE:-0}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

measure_now_ms() {
  perl -MTime::HiRes=time -e 'printf "%.3f", time() * 1000'
}

measure_log_since() {
  local label="$1"
  local start_ms="$2"
  if measure_enabled; then
    local end_ms elapsed_ms
    end_ms="$(measure_now_ms)"
    elapsed_ms="$(awk -v end="$end_ms" -v start="$start_ms" 'BEGIN { printf "%.1f", end - start }')"
    printf '[vis measure] shell:%s %s ms\n' "$label" "$elapsed_ms" >&2
  fi
}

measure_log() {
  if measure_enabled; then
    printf '[vis measure] shell:%s\n' "$1" >&2
  fi
}

run_measured_or_exec() {
  local label="$1"
  shift
  if measure_enabled; then
    local start_ms code
    start_ms="$(measure_now_ms)"
    "$@"
    code=$?
    measure_log_since "$label exit=$code" "$start_ms"
    exit "$code"
  else
    exec "$@"
  fi
}

args=()
for arg in "$@"; do
  if [[ "$arg" == "--measure" ]]; then
    export VIS_MEASURE=1
  else
    args+=("$arg")
  fi
done
set -- "${args[@]}"

# svar SSE per-line trace - see bin/vis for the full rationale. OFF
# by default; opt in with VIS_STREAM_TRACE=1. Same flag, same env var,
# same effect on the dev nREPL JVM (where `dev/tui!` also launches the
# Terminal.app JVM from, so a stuck stream inside the dev path remains
# observable when explicitly requested).
stream_trace_jvm_opts=()
case "${VIS_STREAM_TRACE:-0}" in
  1|true|TRUE|yes|YES|on|ON)
    stream_trace_jvm_opts=("-J-Dsvar.stream.trace=true")
    measure_log "svar stream trace enabled"
    ;;
esac

measure_log "exec cold clojure -M:test:dev"
run_measured_or_exec "process cold clojure -M:test:dev" clojure "${stream_trace_jvm_opts[@]}" -M:test:dev "$@"
