{:paths ["src" "resources"]

 :deps
 {org.clojure/clojure                       {:mvn/version "1.12.4"}
  ;; ---- vis monorepo siblings ---------------------------------------------
  ;; Each lives under packages/. Local-root keeps them in sync during
  ;; development; the published artifacts will use Maven coordinates.
  com.blockether/vis-extension              {:local/root "../vis-extension"}
  ;; Reusable command-line primitives (`vis-commandline/command`,
  ;; arg parsing, dispatch, help rendering). The `cli.clj` dispatcher
  ;; assembles the entire `vis` command tree out of these.
  com.blockether/vis-commandline            {:local/root "../vis-commandline"}
  ;; Persistence FACADE — the public API + spec only, no JDBC.
  ;; vis-core hard-depends on the facade; concrete backends (e.g.
  ;; vis-persistance-sqlite) plug themselves in at load time via
  ;; `META-INF/vis/persistance-backends.edn`. vis-core has ZERO direct
  ;; reference to any backend namespace.
  com.blockether/vis-persistance            {:local/root "../vis-persistance"}

  hiccup/hiccup                             {:mvn/version "2.0.0"}
  ;; LLM structured output
  com.blockether/svar                       {:mvn/version "0.3.10"}
  ;; Anomaly - standardized error categories (used by RLM)
  com.blockether/anomaly                    {:mvn/version "1.0.1"}
  ;; Browser automation (Playwright)
  com.blockether/spel                       {:mvn/version "0.9.7"}
  ;; Ring — Jetty adapter
  ring/ring-jetty-adapter                   {:mvn/version "1.15.4"}
  ;; Reitit — data-driven router
  metosin/reitit-ring                       {:mvn/version "0.10.1"}
  ;; nREPL — embedded in dev + prod
  nrepl/nrepl                               {:mvn/version "1.7.0"}
  ;; Structured telemetry
  com.taoensso/telemere                     {:mvn/version "1.2.1"}
  com.taoensso/telemere-slf4j               {:mvn/version "1.2.1"}

  ;; Fast EDN parsing
  io.github.tonsky/fast-edn                 {:mvn/version "1.1.3"}
  ;; i18n — pluralization and translations
  tongue/tongue                             {:mvn/version "0.4.4"}
  ;; Dependency injection
  org.clojars.darkleaf/di                   {:mvn/version "3.6.0"}
  ;; JSON serialization (CLI output, agent results)
  com.cnuernber/charred                     {:mvn/version "1.038"}

  ;; ---- RLM stack (moved from svar) ----
  ;; Filesystem utilities
  babashka/fs                               {:mvn/version "0.5.33"}
  ;; SCI - Small Clojure Interpreter (RLM sandbox)
  org.babashka/sci                          {:mvn/version "0.12.51"}
  ;; HTTP client (pageindex vision calls etc.)
  org.babashka/http-client                  {:mvn/version "0.4.23"}
  ;; zprint - pretty printer (RLM sandbox)
  zprint/zprint                             {:mvn/version "1.3.0"}
  ;; Token counting
  com.knuddels/jtokkit                      {:mvn/version "1.1.0"}
  ;; Edamame — edn/clj reader (richer than clojure.edn)
  borkdude/edamame                          {:mvn/version "1.5.39"}
  ;; PDFBox — PDF processing (pageindex)
  org.apache.pdfbox/pdfbox                  {:mvn/version "3.0.7"}
  ;; core.async — parallel processing (pageindex)
  org.clojure/core.async                    {:mvn/version "1.9.865"}
  ;; lazytest — exposed in RLM SCI sandbox
  io.github.noahtheduke/lazytest            {:mvn/version "2.0.0"}
  ;; JGit — pure-JVM git library (RLM git ingestion)
  org.eclipse.jgit/org.eclipse.jgit         {:mvn/version "7.6.0.202603022253-r"}
  ;; yamlstar — YAML 1.2 loader (SKILL.md frontmatter)
  org.yamlstar/yamlstar                     {:mvn/version "0.1.3"}
  ;; clojure+ — cond+/if+/when+ macros + enhanced walk (SCI sandbox)
  io.github.tonsky/clojure-plus             {:mvn/version "1.7.2"}
  ;; jmustache — Mustache templating (RLM answer interpolation)
  com.samskivert/jmustache                  {:mvn/version "1.16"}}

 :aliases
 {:test  {;; Pull the SQLite backend in as a TEST-ONLY dep so the
          ;; persistance facade has at least one backend at test time.
          ;; vis-core's runtime classpath stays backend-agnostic.
          ;; Also pulls the shared SQLite test helpers from
          ;; `vis-persistance-sqlite/test/`.
          :extra-paths ["test" "../vis-persistance-sqlite/test"]
          :extra-deps  {io.github.noahtheduke/lazytest        {:mvn/version "2.0.0"}
                        com.blockether/vis-persistance-sqlite {:local/root "../vis-persistance-sqlite"}}
          :main-opts   ["-m" "lazytest.main"]}}}
