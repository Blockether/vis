{:paths ["src" "resources"]
 ;; GitHub Copilot OAuth provider — device-flow authentication +
 ;; token lifecycle. Self-registers with `com.blockether.vis.provider`
 ;; at namespace load via `META-INF/vis/providers.edn`.
 :deps
 {org.clojure/clojure       {:mvn/version "1.12.4"}
  com.blockether/vis-provider {:local/root "../vis-provider"}
  ;; HTTP client for the device-flow + token-exchange calls.
  org.babashka/http-client  {:mvn/version "0.4.23"}
  ;; JSON parsing for the OAuth + token-exchange responses.
  com.cnuernber/charred     {:mvn/version "1.038"}
  com.taoensso/telemere     {:mvn/version "1.2.1"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.noahtheduke/lazytest {:mvn/version "2.0.0"}}
   :main-opts  ["-m" "lazytest.main" "--dir" "test"]}}}
