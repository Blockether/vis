{:paths ["src"]
 ;; vis-runtime — ONLY the iteration loop logic.
 ;;
 ;; Owns:
 ;;   - The recursive language model (RLM) iteration runtime
 ;;   - The SCI sandbox (`environment/core`)
 ;;   - The query engine + iteration spec
 ;;   - The conversations runtime (env cache, `send!`, lifecycle)
 ;;   - The public API facade `com.blockether.vis-runtime.core`
 ;;
 ;; svar lives ONLY here — channels reach svar through the registry
 ;; in vis-sdk.core (`register-runtime-impl!` / `runtime-impl`),
 ;; which vis-runtime populates at namespace load.
 ;;
 ;; Depends on:
 ;;   - vis-sdk          (contracts + cross-channel runtime helpers)
 ;;
 ;; Depended on by:
 ;;   - vis-main         (the `vis` binary)
 ;;
 ;; Extensions DO NOT depend on this package. They depend on vis-sdk
 ;; only and reach the iteration loop through vis-sdk's conversation
 ;; facade.
 :deps
 {org.clojure/clojure                       {:mvn/version "1.12.4"}
  com.blockether/vis-sdk                    {:local/root "../vis-sdk"}

  ;; LLM structured output — the only svar consumer in the monorepo.
  com.blockether/svar                       {:mvn/version "0.3.11"}
  ;; Anomaly — standardized error categories used by the loop.
  com.blockether/anomaly                    {:mvn/version "1.0.1"}
  ;; Structured telemetry.
  com.taoensso/telemere                     {:mvn/version "1.2.1"}

  ;; ---- RLM stack ----
  ;; SCI — Small Clojure Interpreter (RLM sandbox).
  org.babashka/sci                          {:mvn/version "0.12.51"}
  ;; Edamame — edn/clj reader (richer than clojure.edn).
  borkdude/edamame                          {:mvn/version "1.5.39"}
  ;; lazytest — exposed in the RLM SCI sandbox.
  io.github.noahtheduke/lazytest            {:mvn/version "2.0.0"}
  ;; clojure-plus — cond+/if+/when+ macros + enhanced walk (SCI sandbox).
  io.github.tonsky/clojure-plus             {:mvn/version "1.7.2"}
  ;; jmustache — Mustache templating for RLM answer interpolation.
  com.samskivert/jmustache                  {:mvn/version "1.16"}

  ;; ---- SCI sandbox bindings ----
  ;; fast-edn / charred are exposed to user code inside the SCI sandbox
  ;; via `ns->sci-map`; both are required at runtime even though
  ;; vis-runtime's source never `(:require ...)`s them at the top level.
  io.github.tonsky/fast-edn                 {:mvn/version "1.1.3"}
  com.cnuernber/charred                     {:mvn/version "1.038"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps  {io.github.noahtheduke/lazytest {:mvn/version "2.0.0"}}
   :main-opts   ["-m" "lazytest.main"]}}}
