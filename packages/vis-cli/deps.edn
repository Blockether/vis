{:paths ["src" "resources"]
 ;; vis-cli — the binary's CLI surface.
 ;;
 ;; Owns:
 ;;   - com.blockether.vis-cli.commandline.main   (the `vis <subcommand>` dispatcher)
 ;;   - com.blockether.vis-cli.channels.cli       (built-in commands: run, auth, doctor, conversations, extensions list)
 ;;   - com.blockether.vis-cli.channels.cli.agent (one-shot agent helper used by `vis run`)
 ;;
 ;; Ships its own `META-INF/vis-extension/vis.edn` so the unified
 ;; loader registers `channels.cli` at boot, which in turn calls
 ;; `register-global!` for every built-in command.
 ;;
 ;; Depends on vis-loop for the loop/conversations API, vis-extension
 ;; for the contracts, and vis-persistance for the storage facade.
 :deps
 {org.clojure/clojure              {:mvn/version "1.12.4"}
  com.blockether/vis-loop          {:local/root "../vis-loop"}
  com.blockether/vis-extension     {:local/root "../vis-extension"}
  com.blockether/vis-persistance   {:local/root "../vis-persistance"}
  ;; svar.internal.llm — used by channels.cli.agent for the one-shot
  ;; agent helper that powers `vis run`.
  com.blockether/svar              {:mvn/version "0.3.11"}
  ;; charred — JSON serialization for `vis run --json` output.
  com.cnuernber/charred            {:mvn/version "1.038"}
  com.taoensso/telemere            {:mvn/version "1.2.1"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps  {io.github.noahtheduke/lazytest {:mvn/version "2.0.0"}}
   :main-opts   ["-m" "lazytest.main"]}}}
