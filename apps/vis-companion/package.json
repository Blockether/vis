{
  "name": "vis-companion",
  "version": "0.1.0",
  "private": true,
  "description": "Universal (web / Android / iOS) companion for the vis gateway — React + Tailwind + Capacitor.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "sync": "cap sync",
    "android": "cap run android",
    "ios": "cap run ios",
    "add:android": "cap add android",
    "add:ios": "cap add ios"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "8.1.0",
    "@capacitor/app": "8.1.1",
    "@capacitor/camera": "8.2.1",
    "@capacitor/core": "8.4.2",
    "@capacitor/preferences": "8.0.1",
    "@capawesome/capacitor-file-picker": "8.0.3",
    "@fontsource-variable/inter": "5.3.0",
    "@fontsource-variable/jetbrains-mono": "5.3.0",
    "jsqr": "1.4.0",
    "prismjs": "1.30.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.2",
    "@capacitor/cli": "8.4.2",
    "@capacitor/ios": "8.4.2",
    "@tailwindcss/vite": "4.3.3",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  }
}
